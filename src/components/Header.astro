---
import { Image } from 'astro:assets'
import logo from 'src/assets/logo.png'
---

<header>
  <a href="/recipes/">
    <Image src={logo} alt="Logo" class="logo" />
  </a>
  <nav>
    <ul>
      <li><a href="/recipes/">Home</a></li>
    </ul>
    <ul>
      <li><a href="/recipes/">Recipes</a></li>
    </ul>
    <ul>
      <li><a href="/recipes/tags/">Tags</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
    padding: 0.5rem 1rem;
    background-color: white;
    color: black;
  }

  .logo {
    width: 150px;
    height: 100%;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  nav ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav ul li {
    margin-right: 1rem;
  }

  a {
    color: black;
    text-decoration: none;
  }

  @media (max-width: 480px) {
    .logo {
      width: 100px;
    }

    nav {
      gap: 0.25rem;
      font-size: 0.9rem;
    }

    nav ul li {
      margin-right: 0.5rem;
    }
  }
</style>
