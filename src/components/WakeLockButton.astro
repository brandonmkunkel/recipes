---
const BUTTON_TEXT_OFF = 'Start Cooking Mode'
const BUTTON_TEXT_ON = 'Cooking Mode On'
const HELPER_TEXT_OFF = 'turn this on to keep your screen awake while cooking'
const HELPER_TEXT_ON = 'your screen will stay awake while cooking, click to turn off'
---

<div class="cooking-mode-wrapper">
  <button id="wake-lock-btn" class="wake-lock-btn">{BUTTON_TEXT_OFF}</button>
  <span id="cooking-mode-description" class="cooking-mode-description">{HELPER_TEXT_OFF}</span>
</div>

<script is:inline define:vars={{ BUTTON_TEXT_OFF, BUTTON_TEXT_ON, HELPER_TEXT_OFF, HELPER_TEXT_ON }}>
  let wakeLock = null
  const btn = document.getElementById('wake-lock-btn')
  const descriptive_text = document.getElementById('cooking-mode-description')

  if (btn && 'wakeLock' in navigator) {
    btn.addEventListener('click', async () => {
      if (wakeLock) {
        wakeLock.release()
        wakeLock = null
        btn.textContent = BUTTON_TEXT_OFF
        btn.classList.remove('active')
        descriptive_text.textContent = HELPER_TEXT_OFF
      } else {
        try {
          wakeLock = await navigator.wakeLock.request('screen')
          btn.textContent = BUTTON_TEXT_ON
          btn.classList.add('active')
          descriptive_text.textContent = HELPER_TEXT_ON

          wakeLock.addEventListener('release', () => {
            wakeLock = null
            btn.textContent = BUTTON_TEXT_OFF
            btn.classList.remove('active')
            descriptive_text.textContent = HELPER_TEXT_OFF
          })
        } catch (err) {
          console.error('Failed to request wake lock:', err)
        }
      }
    })
  } else if (btn) {
    btn.disabled = true
    btn.textContent = 'Not Supported'
  }
</script>

<style>
  .cooking-mode-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .cooking-mode-description {
    font-size: 0.875rem;
    color: #666;
  }

  .wake-lock-btn {
    background: #6c757d;
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    white-space: nowrap;
  }

  .wake-lock-btn:hover {
    background: #5a6268;
  }

  .wake-lock-btn.active {
    background: #4caf50;
  }

  .wake-lock-btn.active:hover {
    background: #45a049;
  }

  .wake-lock-btn:disabled {
    background: #cccccc;
    cursor: not-allowed;
  }
</style>
