---
import Breadcrumbs from './Breadcrumbs.astro'
import WakeLockButton from './WakeLockButton.astro'

const { title, url, tags, description, source, prepTime, cookTime, totalTime, yield: recipeYield } = Astro.props

const crumbs = [{ label: 'Home', href: '/recipes/' }, { label: 'Recipes', href: '/recipes/' }, { label: title }]
---

<article>
  <Breadcrumbs crumbs={crumbs} />
  <h1>{title}</h1>
  <nav>
    {
      tags && tags.length > 0 && (
        <div class="tags-inline">
          <span class="tags-label">Tags</span>
          <ul class="tag-list inline">
            {tags.map((t: string) => (
              <li>
                <a href={`/recipes/tags/${t}/`}>{t}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </nav>

  <p>
    {description}
    {
      source && (
        <a href={source} target="_blank" rel="noreferrer">
          Source
        </a>
      )
    }
  </p>

  {
    (prepTime || cookTime || totalTime || recipeYield) && (
      <dl class="recipe-meta">
        {prepTime && (
          <div>
            <dt>Prep Time</dt>
            <dd>{prepTime}</dd>
          </div>
        )}
        {cookTime && (
          <div>
            <dt>Cook Time</dt>
            <dd>{cookTime}</dd>
          </div>
        )}
        {totalTime && (
          <div>
            <dt>Total Time</dt>
            <dd>{totalTime}</dd>
          </div>
        )}
        {recipeYield && (
          <div>
            <dt>Yield</dt>
            <dd>{recipeYield}</dd>
          </div>
        )}
      </dl>
    )
  }

  <WakeLockButton />

  <div class="recipe-body">
    <slot />
  </div>
</article>

<style>
  article {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem;
  }

  h1 h2 h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .tags-inline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .tags-label {
    font-weight: 600;
    margin: 0;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-list.inline {
    display: inline-flex;
    align-items: center;
  }

  .tag-list li a {
    background: #efefef;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
  }

  .recipe-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    background: #f8f8f8;
    border-radius: 6px;
  }

  .recipe-meta div {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1 1 4rem;
    padding: 0.25rem 0.5rem;
  }

  .recipe-meta dt {
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #666;
    margin-bottom: 0.2rem;
  }

  .recipe-meta dd {
    margin: 0;
    font-size: 0.9rem;
  }

  @media (max-width: 480px) {
    .recipe-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .recipe-meta div {
      flex: unset;
    }
  }

  .recipe-body {
    margin-top: 1rem;
  }
</style>
