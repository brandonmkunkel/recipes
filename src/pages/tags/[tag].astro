---
import { getCollection } from 'astro:content'

import Layout from '~/layouts/Layout.astro'
import Header from '~/components/Header.astro'
import SearchBar from '~/components/SearchBar.astro'
import Breadcrumbs from '~/components/Breadcrumbs.astro'

export async function getStaticPaths() {
  const recipes = await getCollection('recipes')
  const tags = new Set()

  for (const r of recipes) {
    const t = r.data.tags ?? []
    for (const tag of t) tags.add(tag)
  }

  return Array.from(tags).map((tag) => ({ params: { tag }, props: { tag } }))
}

const { tag } = Astro.props as { tag: string }

const recipes = await getCollection('recipes')
const matched = recipes
  .filter((r) => (r.data.tags ?? []).includes(tag))
  .sort((a, b) => (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id))

const crumbs = [{ label: 'Home', href: '/recipes/' }, { label: 'Tags', href: '/recipes/tags/' }, { label: tag }]
---

<Layout title={`Tag: ${tag}`}>
  <Header />
  <SearchBar />

  <main>
    <Breadcrumbs crumbs={crumbs} />
    <h1>
      Tag:
      <span class="tag-chip">{tag}</span>
    </h1>

    {
      matched.length === 0 ? (
        <p>No recipes found for this tag.</p>
      ) : (
        <div class="recipes-list">
          {matched.map((r) => (
            <a href={`/recipes/${r.id}/`} class="recipe-link">
              {r.data.title ?? r.id}
            </a>
          ))}
        </div>
      )
    }
  </main>
</Layout>

<style>
  h1 {
    margin-bottom: 1rem;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    margin: 0.5rem 0;
  }
</style>
