---
import { getCollection, getEntry, render } from 'astro:content'

import Header from '~/components/Header.astro'
import SearchBar from '~/components/SearchBar.astro'
import Layout from '~/layouts/Layout.astro'
import Recipe from '~/components/Recipe.astro'

export async function getStaticPaths() {
  const recipes = await getCollection('recipes')

  const pages = recipes.map((recipe) => {
    return {
      params: { slug: recipe.id }, // Define the dynamic slug here
      props: {
        slug: recipe.id,
        title: recipe.data.title ?? recipe.id,
        text: recipe.body,
        tags: recipe.data.tags ?? [],
        description: recipe.data.description ?? '',
        source: recipe.data.source ?? null,
        prepTime: recipe.data.prepTime ?? null,
        cookTime: recipe.data.cookTime ?? null,
        totalTime: recipe.data.totalTime ?? null,
        yield: recipe.data.yield ?? null,
      },
    }
  })

  return pages
}

const { title, tags, text, slug, description, source, prepTime, cookTime, totalTime, yield: recipeYield } = Astro.props

const entry = await getEntry('recipes', slug)
if (!entry) {
  // Handle Error, for example:
  throw new Error('Could not find blog post')
}
const { Content, headings } = await render(entry)
---

<Layout title={title}>
  <Header />
  <SearchBar />

  <Recipe
    title={title}
    tags={tags}
    description={description}
    source={source}
    prepTime={prepTime}
    cookTime={cookTime}
    totalTime={totalTime}
    yield={recipeYield}
  >
    <Content />
  </Recipe>
</Layout>

<style>
  .tags {
    margin-top: 1.5rem;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-list li a {
    background: #efefef;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
  }
</style>
